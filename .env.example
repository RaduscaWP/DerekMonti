# Resend API key — used by api/quote.js to send the boarding-pass ticket email.
# Sign up at https://resend.com (free tier = 3000 emails/month, no card required),
# create an API key, then in Vercel: Settings -> Environment Variables -> add it.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxx

# Optional. Override the "From" address used by api/quote.js. Use this once your
# sending domain is verified in Resend (with SPF/DKIM/DMARC). Until then the code
# falls back to Resend's shared sandbox sender, which often lands in spam.
# Format: "Display Name <noreply@your-verified-domain.com>"
# MAIL_FROM_ADDRESS=Derek Monti <noreply@derekmonti.com>

# Optional. Cloudflare Turnstile — bot/abuse protection for the quote form.
# Create a site at https://dash.cloudflare.com/?to=/:account/turnstile and add
# both keys to Vercel. If unset, the server skips verification and the client
# does not render the widget (useful for local dev without internet access).
# Client (must start with VITE_ so Vite exposes it):
# VITE_TURNSTILE_SITE_KEY=0x4AAAAAAAxxxxxxxxxxxx
# Server (keep secret, never commit):
# TURNSTILE_SECRET=0x4AAAAAAAxxxxxxxxxxxx

# Optional. Distributed rate limiter (Upstash Redis via Vercel Marketplace).
# Without these, api/quote.js falls back to per-instance in-memory limits.
# Either pair works — the code accepts both naming conventions.
# UPSTASH_REDIS_REST_URL=https://xxxx.upstash.io
# UPSTASH_REDIS_REST_TOKEN=xxxx
# KV_REST_API_URL=https://xxxx.upstash.io
# KV_REST_API_TOKEN=xxxx

# Optional. Used by the email template to build absolute image URLs.
# PUBLIC_SITE_URL=https://derekmonti.com
